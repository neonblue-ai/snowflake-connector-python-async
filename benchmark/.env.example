# Snowflake Connection Parameters for Benchmarking
# Copy this file to .env and fill in your actual credentials
# Uses official Snowflake environment variable names

# Account and user (required)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=

# Authentication - use either password OR private key
# SNOWFLAKE_PASSWORD=your_password

# Private key authentication (recommended) - use ONE of these methods:

# Method 1: Private key file path (recommended)
SNOWFLAKE_PRIVATE_KEY_PATH=

# Method 2: Private key as raw content
# SNOWFLAKE_PRIVATE_KEY_RAW="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# Database and schema (must exist)
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=

# Optional: Role
# SNOWFLAKE_ROLE=